#cloud-config
bootcmd:
  # Resize the partition (4 = /dev/nvme0n1p4 typically)
  - growpart /dev/nvme0n1 4
runcmd:
  - systemctl enable --now kubelet
  - /usr/local/bin/crc-aws-fetch-secrets.sh "{{ .SSMPullSecretName }}" "{{ .SSMKubeAdminPasswordName }}" "{{ .SSMDeveloperPasswordName }}"
write_files:
- path: /opt/crc/eip
  content: "{{ .PublicIP }}"
  owner: root:root
  permissions: '0644'
- path: /home/core/.ssh/authorized_keys
  content: {{ .PubKey }}
  owner: {{ .Username }}
  permissions: '0600'
- path: /opt/crc/id_rsa.pub
  content: {{ .PubKey }}
  owner: root:root
  permissions: '0644'
- content: |
      CRC_SELF_SUFFICIENT=1
      CRC_NETWORK_MODE_USER=0
  owner: root:root
  path: /etc/sysconfig/crc-env
  permissions: '0644'
